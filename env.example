# ==============================================================================
# DARKBET ENVIRONMENT VARIABLES EXAMPLE
# ==============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to git!
# ==============================================================================

# ------------------------------------------------------------------------------
# PRIVY AUTHENTICATION (Required)
# ------------------------------------------------------------------------------
# Get your App ID from: https://dashboard.privy.io
# 1. Sign up/login to Privy
# 2. Create a new app
# 3. Copy your App ID (looks like: clpXXXXXXXXXXXXXX)
# 4. Add http://localhost:3000 to allowed origins in Privy dashboard
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# Privy App Secret (for server-side API calls)
# Get from: https://dashboard.privy.io > Settings > API Keys
PRIVY_APP_SECRET=your_privy_app_secret_here

# ------------------------------------------------------------------------------
# MONGODB DATABASE (Required for Production)
# ------------------------------------------------------------------------------
# Local Development (default)
MONGODB_URI=mongodb://localhost:27017/darkbet

# Or use MongoDB Atlas (cloud)
# Get from: https://cloud.mongodb.com
# Example: mongodb+srv://username:password@cluster.mongodb.net/darkbet?retryWrites=true&w=majority
# MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/darkbet?retryWrites=true&w=majority

# Database name (optional, defaults to 'darkbet')
MONGODB_DB_NAME=darkbet

# ------------------------------------------------------------------------------
# SOLANA BLOCKCHAIN
# ------------------------------------------------------------------------------
# Solana RPC URL
# Devnet (for testing)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Or use Mainnet (production)
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Or use private RPC (recommended for production)
# Get from: https://www.helius.dev or https://www.quicknode.com
# NEXT_PUBLIC_SOLANA_RPC_URL=https://YOUR-RPC-ENDPOINT.solana-mainnet.quiknode.pro/YOUR_TOKEN/

# Solana Network (devnet, testnet, mainnet-beta)
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Deployed Program IDs (update after deploying your Solana programs)
NEXT_PUBLIC_PREDICTION_PROGRAM_ID=
NEXT_PUBLIC_VAULT_PROGRAM_ID=

# Admin wallet private key (for market resolution, backend only)
# NEVER expose this in frontend!
SOLANA_ADMIN_PRIVATE_KEY=

# ------------------------------------------------------------------------------
# CONCORDIUM BLOCKCHAIN (Identity & Responsible Gambling)
# ------------------------------------------------------------------------------
# Using official @concordium/id-app-sdk for identity verification
# Documentation: https://www.npmjs.com/package/@concordium/id-app-sdk
# See: docs/CONCORDIUM_ID_APP_SETUP.md for detailed setup

# Concordium Network (testnet or mainnet)
CONCORDIUM_NETWORK=testnet

# Concordium Node URL
# Testnet
CONCORDIUM_NODE_URL=https://grpc.testnet.concordium.com
CONCORDIUM_NODE_PORT=20000

# Or Mainnet (production)
# CONCORDIUM_NODE_URL=https://grpc.mainnet.concordium.software
# CONCORDIUM_NODE_PORT=20000

# Concordium RG Registry Contract Address (update after deployment)
CONCORDIUM_RG_CONTRACT_ADDRESS=

# Concordium Contract Index (after deployment)
CONCORDIUM_RG_CONTRACT_INDEX=

# Concordium Wallet for contract interactions (backend only)
CONCORDIUM_WALLET_FILE=
CONCORDIUM_WALLET_PASSWORD=

# ------------------------------------------------------------------------------
# WALLETCONNECT (Optional but Recommended)
# ------------------------------------------------------------------------------
# Get from: https://cloud.walletconnect.com
# Create a free account and get your project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ------------------------------------------------------------------------------
# PYTH NETWORK (Price Oracles for Solana)
# ------------------------------------------------------------------------------
# Pyth Program ID (usually doesn't need to change)
NEXT_PUBLIC_PYTH_PROGRAM_ID=FsJ3A3u2vn5cTVofAjvy6y5kwABJAqYWpe4975bi2epH

# Pyth Price Feed IDs (Solana Devnet)
NEXT_PUBLIC_PYTH_BTC_FEED=HovQMDrbAgAYPCmHVSrezcSmkMtXSSUsLDFANExrZh2J
NEXT_PUBLIC_PYTH_ETH_FEED=JBu1AL4obBcCMqKBBxhpWCNUt136ijcuMZLFvTP7iWdB
NEXT_PUBLIC_PYTH_SOL_FEED=J83w4HKfqxwcq3BEMMkPFSppX3gqekLyLJBexebFVkix

# ------------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# ------------------------------------------------------------------------------
# Environment
NODE_ENV=development

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api

# Backend URL (if using separate backend)
BACKEND_URL=http://localhost:3001

# ------------------------------------------------------------------------------
# AI SERVICE (Optional - for market descriptions/summaries)
# ------------------------------------------------------------------------------
# Provider: openai, anthropic, gemini, or custom
NEXT_PUBLIC_AI_PROVIDER=gemini

# OpenAI
# Get from: https://platform.openai.com/api-keys
NEXT_PUBLIC_OPENAI_API_KEY=
NEXT_PUBLIC_OPENAI_MODEL=gpt-4

# Anthropic Claude
# Get from: https://console.anthropic.com
NEXT_PUBLIC_ANTHROPIC_API_KEY=
NEXT_PUBLIC_ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Google Gemini
# Get from: https://makersuite.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=
NEXT_PUBLIC_GEMINI_MODEL=gemini-1.5-flash

# ------------------------------------------------------------------------------
# SECURITY & ADMIN
# ------------------------------------------------------------------------------
# Admin API Key (for protected endpoints)
ADMIN_API_KEY=your_secure_random_string_here

# Oracle Admin Key (for market resolution)
ORACLE_ADMIN_KEY=your_oracle_admin_key_here

# JWT Secret (for API authentication)
JWT_SECRET=your_jwt_secret_here

# Encryption Key (for sensitive data)
ENCRYPTION_KEY=your_encryption_key_here

# ------------------------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------------------------
# Enable/disable features
NEXT_PUBLIC_ENABLE_CONCORDIUM=true
NEXT_PUBLIC_ENABLE_RG_FEATURES=true
NEXT_PUBLIC_ENABLE_AI_DESCRIPTIONS=false
NEXT_PUBLIC_ENABLE_SOCIAL_LOGIN=true

# ------------------------------------------------------------------------------
# CONCORDIUM SPECIFIC SETTINGS
# ------------------------------------------------------------------------------
# Minimum age for betting
MINIMUM_AGE=18

# Allowed jurisdictions (comma-separated country codes)
ALLOWED_JURISDICTIONS=US,UK,CA,AU,NZ,SG,JP,KR,CH,SE,NO,DK,FI,DE,FR,ES,IT,NL,BE,AT,IE

# Default RG limits (in SOL)
DEFAULT_DAILY_LIMIT=10
DEFAULT_WEEKLY_LIMIT=50
DEFAULT_MONTHLY_LIMIT=200
DEFAULT_SINGLE_BET_LIMIT=100

# Self-exclusion durations (in days, comma-separated)
SELF_EXCLUSION_DURATIONS=7,30,90,180,365

# ------------------------------------------------------------------------------
# TESTING (for development/testing only)
# ------------------------------------------------------------------------------
# Use mock services in development
USE_MOCK_CONCORDIUM=true
USE_MOCK_PRIVY=false
USE_MOCK_SOLANA=false

# ==============================================================================
# QUICK START GUIDE
# ==============================================================================
# 
# MINIMUM REQUIRED (to get app running):
# 1. NEXT_PUBLIC_PRIVY_APP_ID - Get from https://dashboard.privy.io
# 2. MONGODB_URI - Use mongodb://localhost:27017/darkbet for local
# 3. NEXT_PUBLIC_SOLANA_RPC_URL - Use https://api.devnet.solana.com
#
# HOW TO USE:
# 1. Copy this file: cp env.example .env.local
# 2. Fill in at least the 3 required variables above
# 3. Restart your dev server: npm run dev
#
# MONGODB SETUP:
# - Local: Install MongoDB and use mongodb://localhost:27017/darkbet
# - Cloud: Sign up at https://cloud.mongodb.com (free tier available)
#   - Create cluster → Get connection string → Replace USERNAME and PASSWORD
#
# PRODUCTION:
# - Use environment variables in your hosting platform (Vercel, etc.)
# - Never commit .env.local to git
# - Use strong, random values for all secrets
#
# ==============================================================================

